{

  "java.configuration.updateBuildConfiguration": "automatic",

  "java.jdt.ls.java.home": "D:\\Develop\\jdk-22",

  "java.configuration.runtimes": [

    {

      "name": "JavaSE-22",

      "path": "D:\\Develop\\jdk-22",

      "default": true

    }

  ],

  "java.debug.settings.timeout": 120000,

  "java.debug.settings.console": "integratedTerminal",

  "java.import.maven.enabled": true,

  "maven.terminal.useJavaHome": true,

  "java.compile.nullAnalysis.mode": "disabled",

  "terminal.integrated.env.windows": {

    "JAVA_TOOL_OPTIONS": "-Dfile.encoding=UTF-8 -Dstdout.encoding=UTF-8 -Dstderr.encoding=UTF-8"

  },

  "terminal.integrated.profiles.windows": {

    "PowerShell (UTF-8)": {

      "source": "PowerShell",

      "args": [

        "-NoExit",

        "-Command",

        "[Console]::OutputEncoding = [Console]::InputEncoding = [System.Text.UTF8Encoding]::new($false); chcp 65001 | Out-Null"

      ]

    }

  },

  "terminal.integrated.defaultProfile.windows": "PowerShell (UTF-8)",

  "terminal.integrated.automationProfile.windows": {

    "path": "${env:windir}\\System32\\WindowsPowerShell\\v1.0\\powershell.exe",

    "args": [

      "-NoExit",

      "-Command",

      "[Console]::OutputEncoding = [Console]::InputEncoding = [System.Text.UTF8Encoding]::new($false); chcp 65001 | Out-Null"

    ]

  },

  "markdown-preview-enhanced.configPath": "${workspaceFolder}/.crossnote/config.js"

}


