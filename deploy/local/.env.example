# 复制为 .env 后使用（与 application-local.yml 默认值对齐）
# 国内网络建议取消下面两行注释，使用 DaoCloud 镜像加速

DOCKER_MIRROR=docker.m.daocloud.io
ES_BASE_IMAGE=docker.m.daocloud.io/library/elasticsearch:8.15.3

POSTGRES_DB=asklens
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

ELASTICSEARCH_PORT=9200
ELASTICVUE_PORT=8088

MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=asklens-documents
